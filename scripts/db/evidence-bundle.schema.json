{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterai.internal/schemas/p02-db-evidence-bundle.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractsPreflight", "preflight", "integration", "validation", "manifest"],
  "properties": {
    "contractsPreflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "runId", "generatedAt", "sourceSha", "nodeVersion", "platform", "status", "checks", "cleanup"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "P02_CONTRACT_PREFLIGHT" },
        "runId": { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "nodeVersion": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "const": "PASS" },
        "checks": { "$ref": "#/$defs/contractsChecks" },
        "cleanup": { "$ref": "#/$defs/contractsCleanup" }
      }
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "runId", "generatedAt", "sourceSha", "nodeVersion", "platform", "status", "checks", "cleanup"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "P02_DATABASE_PREFLIGHT" },
        "runId": { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "nodeVersion": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "const": "PASS" },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contracts", "provider"],
          "properties": {
            "contracts": { "$ref": "#/$defs/contracts" },
            "provider": { "$ref": "#/$defs/preflightProvider" }
          }
        },
        "cleanup": { "$ref": "#/$defs/cleanup" }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "runId", "generatedAt", "sourceSha", "nodeVersion", "platform", "status", "skipped", "checks", "cleanup"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "P02_DATABASE_INTEGRATION" },
        "runId": { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "nodeVersion": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "const": "PASS" },
        "skipped": { "const": 0 },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["provider", "migrations", "rls", "roles", "seed", "checksPassed", "checksTotal", "testResults", "testOutputSha256"],
          "properties": {
            "provider": { "$ref": "#/$defs/integrationProvider" },
            "migrations": { "$ref": "#/$defs/migrationLifecycle" },
            "rls": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["relrowsecurity", "relforcerowsecurity", "table_owner", "policyname", "qual", "with_check"],
                "properties": {
                  "relrowsecurity": { "const": true },
                  "relforcerowsecurity": { "const": true },
                  "table_owner": { "type": "string" },
                  "policyname": { "type": "string" },
                  "qual": { "type": "string" },
                  "with_check": { "type": "string" }
                }
              }
            },
            "roles": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["rolname", "rolsuper", "rolbypassrls"],
                "properties": {
                  "rolname": { "type": "string" },
                  "rolsuper": { "type": "boolean" },
                  "rolbypassrls": { "type": "boolean" }
                }
              }
            },
            "seed": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tenant_id", "logical_id", "id"],
                "properties": {
                  "tenant_id": { "type": "string" },
                  "logical_id": { "type": "string" },
                  "id": { "type": "string" }
                }
              }
            },
            "checksPassed": { "type": "integer" },
            "checksTotal": { "type": "integer" },
            "testResults": { "$ref": "#/$defs/testResults" },
            "testOutputSha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "cleanup": { "$ref": "#/$defs/cleanup" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "kind", "runId", "generatedAt", "sourceSha", "nodeVersion", "platform", "status", "commands", "generatedClientHash"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "kind": { "const": "P02_PRISMA_STAGE_GATE" },
        "runId": { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "nodeVersion": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "const": "PASS" },
        "commands": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "exitCode", "outputSha256"],
            "properties": {
              "command": { "type": "array", "minItems": 2, "items": { "type": "string" } },
              "exitCode": { "const": 0 },
              "outputSha256": { "$ref": "#/$defs/sha256" }
            }
          }
        },
        "generatedClientHash": { "$ref": "#/$defs/sha256" }
      }
    },
    "prismaStageGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "gate", "stage", "status", "activationTask", "reason", "fixturesChecked", "invocationId", "generatedAt", "sourceSha", "runnerSha256", "manifestSha256", "expectedManifestSha256", "command", "commandOutputSha256"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "gate": { "const": "prisma:validate" },
        "stage": { "type": "string" },
        "status": { "const": "PASS" },
        "activationTask": { "const": "P02-PR2数据库脚手架" },
        "reason": { "type": "string" },
        "fixturesChecked": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "invocationId": { "type": "string", "pattern": "^[0-9a-f-]{36}$" },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "runnerSha256": { "$ref": "#/$defs/sha256" },
        "manifestSha256": { "$ref": "#/$defs/sha256" },
        "expectedManifestSha256": { "$ref": "#/$defs/sha256" },
        "command": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "commandOutputSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "generatedAt", "codeEvidenceSha", "reports"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string", "pattern": "Z$" },
        "codeEvidenceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "stageEvidenceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "reports": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contracts-preflight.json", "preflight.json", "integration.json", "validation.json"],
          "properties": {
            "contracts-preflight.json": { "$ref": "#/$defs/reportDigest" },
            "preflight.json": { "$ref": "#/$defs/reportDigest" },
            "integration.json": { "$ref": "#/$defs/reportDigest" },
            "validation.json": { "$ref": "#/$defs/reportDigest" },
            "prisma-stage-gate.json": { "$ref": "#/$defs/reportDigest" }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "imageDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "contractsChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contracts"],
      "properties": { "contracts": { "$ref": "#/$defs/contracts" } }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptedSha", "testerReportSha", "contractVersion", "sourceHash"],
      "properties": {
        "acceptedSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "testerReportSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "contractVersion": { "type": "string" },
        "sourceHash": { "$ref": "#/$defs/sha256" }
      }
    },
    "contractsCleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempted", "removed"],
      "properties": {
        "attempted": { "const": false },
        "removed": { "const": false }
      }
    },
    "preflightProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerPlatform", "runnerOs", "runnerArch", "image", "immutableReference", "digest", "inspectedOs", "inspectedArch", "repoDigests", "containerId", "serverVersion", "serverMajor", "lcCollate", "lcCtype", "timezone", "ssl", "citextAvailableVersion", "generatedUuid", "migrationRole"],
      "properties": {
        "dockerPlatform": { "type": "string", "pattern": "^linux/(amd64|arm64)$" },
        "runnerOs": { "const": "linux" },
        "runnerArch": { "type": "string", "pattern": "^(x64|arm64)$" },
        "image": { "const": "postgres:17.10-bookworm" },
        "immutableReference": { "type": "string", "pattern": "^postgres:17\\.10-bookworm@sha256:[a-f0-9]{64}$" },
        "digest": { "$ref": "#/$defs/imageDigest" },
        "inspectedOs": { "const": "linux" },
        "inspectedArch": { "type": "string", "pattern": "^(amd64|arm64)$" },
        "repoDigests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^postgres@sha256:[a-f0-9]{64}$" }
        },
        "containerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "serverVersion": { "type": "string", "pattern": "^17\\.10(?:[ .]|$)" },
        "serverMajor": { "const": 17 },
        "lcCollate": { "const": "en_US.utf8" },
        "lcCtype": { "const": "en_US.utf8" },
        "timezone": { "const": "Etc/UTC" },
        "ssl": { "const": "off" },
        "citextAvailableVersion": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)*$" },
        "generatedUuid": { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$" },
        "migrationRole": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rolsuper", "rolbypassrls"],
          "properties": {
            "rolsuper": { "const": true },
            "rolbypassrls": { "const": true }
          }
        }
      }
    },
    "integrationProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dockerPlatform", "runnerOs", "runnerArch", "image", "immutableReference", "digest", "inspectedOs", "inspectedArch", "repoDigests", "containerId", "serverVersion", "serverMajor", "lcCollate", "lcCtype", "timezone", "ssl"],
      "properties": {
        "dockerPlatform": { "type": "string", "pattern": "^linux/(amd64|arm64)$" },
        "runnerOs": { "const": "linux" },
        "runnerArch": { "type": "string", "pattern": "^(x64|arm64)$" },
        "image": { "const": "postgres:17.10-bookworm" },
        "immutableReference": { "type": "string", "pattern": "^postgres:17\\.10-bookworm@sha256:[a-f0-9]{64}$" },
        "digest": { "$ref": "#/$defs/imageDigest" },
        "inspectedOs": { "const": "linux" },
        "inspectedArch": { "type": "string", "pattern": "^(amd64|arm64)$" },
        "repoDigests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^postgres@sha256:[a-f0-9]{64}$" }
        },
        "containerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "serverVersion": { "type": "string", "pattern": "^17\\.10(?:[ .]|$)" },
        "serverMajor": { "const": 17 },
        "lcCollate": { "const": "en_US.utf8" },
        "lcCtype": { "const": "en_US.utf8" },
        "timezone": { "const": "Etc/UTC" },
        "ssl": { "const": "off" }
      }
    },
    "migrationLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first", "repeat", "existingSchema", "rollback", "concurrent"],
      "properties": {
        "first": { "const": true },
        "repeat": { "const": true },
        "existingSchema": { "$ref": "#/$defs/existingSchema" },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["failed", "partialTableAbsent", "rolledBackRows", "repaired"],
          "properties": {
            "failed": { "const": true },
            "partialTableAbsent": { "const": true },
            "rolledBackRows": { "const": 1 },
            "repaired": { "const": true }
          }
        },
        "concurrent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["safe", "exitCodes", "completedRows"],
          "properties": {
            "safe": { "const": true },
            "exitCodes": { "type": "array", "minItems": 2, "items": { "const": 0 } },
            "completedRows": { "const": 1 }
          }
        }
      }
    },
    "existingSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["independentDatabase", "prepared", "preserved", "completedMigrations", "beforeCatalog", "afterCatalog", "migrationHistory"],
      "properties": {
        "independentDatabase": { "const": true },
        "prepared": { "const": true },
        "preserved": { "const": true },
        "completedMigrations": { "const": 2 },
        "beforeCatalog": { "$ref": "#/$defs/catalogEvidence" },
        "afterCatalog": { "$ref": "#/$defs/catalogEvidence" },
        "migrationHistory": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["migrationName", "checksum", "finished", "rolledBack"],
            "properties": {
              "migrationName": { "type": "string" },
              "checksum": { "$ref": "#/$defs/sha256" },
              "finished": { "const": true },
              "rolledBack": { "const": false }
            }
          }
        }
      }
    },
    "catalogEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload", "sha256"],
      "properties": {
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tables"],
          "properties": {
            "tables": { "type": "array", "minItems": 2, "items": { "type": "string" } }
          }
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "testResults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "failed", "skipped", "todo", "total"],
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "const": 0 },
        "skipped": { "const": 0 },
        "todo": { "const": 0 },
        "total": { "type": "integer" }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempted", "containerId", "removed"],
      "properties": {
        "attempted": { "const": true },
        "containerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "removed": { "const": true }
      }
    },
    "reportDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSha", "sha256", "runner", "runnerSha256"],
      "properties": {
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "runner": { "type": "string" },
        "runnerSha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
