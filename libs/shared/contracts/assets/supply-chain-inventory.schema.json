{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lobsterai.internal/schemas/supply-chain-inventory.schema.json",
  "title": "LobsterAI production supply-chain inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "activationTask",
    "productionNetwork",
    "assets",
    "imageEvidence",
    "signature",
    "waivers"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "status": { "const": "ACTIVE" },
    "activationTask": { "const": "P03-PR3部署供应链" },
    "productionNetwork": { "const": "offline" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/asset" }
    },
    "imageEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/imageEvidence" }
    },
    "signature": { "$ref": "#/$defs/signaturePolicy" },
    "waivers": {
      "type": "array",
      "items": { "$ref": "#/$defs/waiver" }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "sourcePath",
        "source",
        "version",
        "integrity",
        "license",
        "scanStatus",
        "productionEligible",
        "optional"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:@/-]+$" },
        "kind": {
          "enum": ["skill", "openclaw-plugin", "openclaw-extension", "kit", "mcp-package"]
        },
        "sourcePath": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "integrity": { "$ref": "#/$defs/digest" },
        "license": { "type": "string", "minLength": 1 },
        "scanStatus": { "enum": ["platform-reviewed", "blocked", "needs-rescan"] },
        "productionEligible": { "type": "boolean" },
        "optional": { "type": "boolean" }
      }
    },
    "sbom": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "path", "sha256", "imageDigest", "sourceSha"],
      "properties": {
        "format": { "enum": ["spdx-json", "cyclonedx-json"] },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/digest" },
        "imageDigest": { "$ref": "#/$defs/digest" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "imageEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "digest", "sourceSha", "sbom", "criticalFindings"],
      "properties": {
        "image": { "type": "string", "minLength": 1, "not": { "pattern": ":latest(?:$|@)" } },
        "digest": { "$ref": "#/$defs/digest" },
        "sourceSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sbom": { "$ref": "#/$defs/sbom" },
        "criticalFindings": { "type": "integer", "minimum": 0, "maximum": 0 }
      }
    },
    "signaturePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "requiredForPublish", "trustedIdentities"],
      "properties": {
        "status": { "enum": ["ACTIVE", "BLOCKED"] },
        "reason": { "type": "string", "minLength": 1 },
        "requiredForPublish": { "const": true },
        "trustedIdentities": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findingId", "owner", "reason", "expiresAt"],
      "properties": {
        "findingId": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
