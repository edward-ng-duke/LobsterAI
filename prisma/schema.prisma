generator client {
  provider = "prisma-client-js"
  output   = "../libs/server/db/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique @db.Citext
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  agents    Agent[]

  @@map("tenants")
}

model Agent {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  logicalId        String   @map("logical_id")
  name             String
  model            String?
  skillIds         Json     @default("[]") @map("skill_ids")
  workingDirectory String?  @map("working_directory")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, logicalId], map: "agents_tenant_id_logical_id_key")
  @@index([tenantId], map: "agents_tenant_id_idx")
  @@map("agents")
}
